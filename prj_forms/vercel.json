{
  "version": 2,
  "builds": [
    {
      "src": "prj_forms/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "prj_forms/wsgi.py"
    }
  ]
}